  &lt;img class=&#34;slide&#34; src=&#34;http://localhost:1313/images/slideshow/reviews1.png&#34; alt=&#34;评价 1&#34;&gt;
  &lt;img class=&#34;slide&#34; src=&#34;http://localhost:1313/images/slideshow/reviews2.png&#34; alt=&#34;评价 2&#34;&gt;
