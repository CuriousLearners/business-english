  &lt;img class=&#34;slide&#34; src=&#34;http://localhost:1313/images/slideshow/reviews4.png&#34; alt=&#34;评价 4&#34;&gt;
  &lt;img class=&#34;slide&#34; src=&#34;http://localhost:1313/images/slideshow/reviews5.png&#34; alt=&#34;评价 5&#34;&gt;
  &lt;img class=&#34;slide&#34; src=&#34;http://localhost:1313/images/slideshow/reviews6.png&#34; alt=&#34;评价 6&#34;&gt;
&lt;/div&gt;
&lt;script&gt;
  let slides = document.querySelectorAll(&#39;.slide&#39;);
  let index = 0;
  function showNextSlide() {
    slides.forEach((img, i) =&gt; {
      img.style.display = i === index ? &#39;block&#39; : &#39;none&#39;;
    });
    index = (index + 1) % slides.length;
  }
  showNextSlide();
  setInterval(showNextSlide, 8000);
&lt;/script&gt;
&lt;style&gt;
  .slideshow-container {
    max-width: 600px;
    margin: 1.5em auto;
    position: relative;
  }

